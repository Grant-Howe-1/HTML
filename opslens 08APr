}

/* list pane */
.list-pane {
width: 280px;
background: #fafafa;
border-right: 1px solid #ddd;
flex-shrink: 0;
overflow-y: auto;
}
.list-header {
padding: 14px 16px;
font-weight: 700;
font-size: 13px;
border-bottom: 1px solid #eee;
color: #222;
}
.email-item {
padding: 12px 16px;
border-bottom: 1px solid #f0f0f0;
cursor: pointer;
font-size: 12px;
}
.email-item.selected { background: #e8f0e8; border-left: 3px solid #2d6a4f; }
.email-item .sender { font-weight: 700; color: #111; margin-bottom: 2px; }
.email-item .subject { color: #333; margin-bottom: 2px; font-weight: 500; font-size: 11.5px; }
.email-item .preview { color: #888; font-size: 11px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.email-item .time { color: #aaa; font-size: 10px; float: right; }
.email-item .unread-dot { width: 7px; height: 7px; border-radius: 50%; background: #2d6a4f; display: inline-block; margin-right: 6px; vertical-align: middle; }

/* reading pane */
.reading-pane {
flex: 1;
overflow-y: auto;
background: #f5f5f5;
}

/* ── EMAIL ITSELF ───────────────────────────────────────── */
.email-outer {
max-width: 680px;
margin: 20px auto;
background: #ffffff;
