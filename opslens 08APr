}

/* KPI GRID */
.kpi-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 10px;
margin-bottom: 22px;
}
.kpi-card {
border: 1px solid #e8e8e8;
border-radius: 8px;
padding: 14px 16px;
background: #fff;
position: relative;
overflow: hidden;
}
.kpi-card::before {
content: '';
position: absolute;
top: 0; left: 0; right: 0;
height: 3px;
}
.kpi-card.green::before { background: #2d6a4f; }
.kpi-card.amber::before { background: #e07000; }
.kpi-card.red::before { background: #c0392b; }

.kpi-name { font-size: 10.5px; color: #888; font-weight: 500; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
.kpi-row { display: flex; gap: 16px; align-items: flex-end; }
.kpi-block { flex: 1; }
.kpi-label { font-size: 9.5px; color: #aaa; margin-bottom: 2px; text-transform: uppercase; letter-spacing: 0.5px; }
.kpi-value { font-size: 22px; font-weight: 800; letter-spacing: -0.5px; font-family: 'DM Mono', monospace; }
.kpi-value.good { color: #1b4332; }
.kpi-value.warn { color: #e07000; }
.kpi-value.bad { color: #c0392b; }
.kpi-sla { font-size: 9px; color: #aaa; margin-top: 2px; }
.kpi-delta {
font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 10px; margin-bottom: 4px; white-space: nowrap;
}
.delta-up { background: #d4edda; color: #1b4332; }
.delta-down { background: #fde8e8; color: #c0392b; }
.delta-flat { background: #f0f0f0; color: #777; }

.kpi-bar-wrap { margin-top: 8px; background: #f0f0f0; border-radius: 4px; height: 4px; overflow: hidden; }
.kpi-bar { height: 100%; border-radius: 4px; }
.kpi-bar.green { background: #2d6a4f; }
.kpi-bar.amber { background: #e07000; }
.kpi-bar.red { background: #c0392b; }

/* highlights */
.highlights { margin-bottom: 22px; }
