background: linear-gradient(135deg, #1b4332 0%, #2d6a4f 60%, #40916c 100%);
padding: 28px 32px 24px;
display: flex;
align-items: center;
justify-content: space-between;
}
.banner-logo {
display: flex; align-items: center; gap: 12px;
