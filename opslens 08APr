background: #fff;
padding: 18px 28px 14px;
border-bottom: 1px solid #eee;
}
.email-subject-line {
font-size: 17px;
font-weight: 700;
color: #111;
margin-bottom: 10px;
}
.email-from-row {
display: flex;
align-items: center;
gap: 10px;
font-size: 12px;
color: #555;
}
.avatar-ai {
